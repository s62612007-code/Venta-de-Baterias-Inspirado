# Plantilla de configuración – Venta de Baterías Inspirado
# Copiar a .env para integraciones futuras (panel admin, WhatsApp, BD)

PORT=8080

# Punto de inicio domicilios (Cali)
DOMICILIO_DIRECCION=Carrera 54A #7-05
DOMICILIO_LAT=3.42412
DOMICILIO_LNG=-76.54538

# Tarifas domicilio (COP)
DOMICILIO_ZONA1_KM=1.5
DOMICILIO_ZONA1_PRECIO=15000
DOMICILIO_ZONA2_KM=8
DOMICILIO_ZONA2_PRECIO=25000

# Promociones
DESCUENTO_BATERIA_USADA=30000
DESCUENTO_VECINDAD=35000

# Integraciones futuras
DATABASE_URL=
API_KEY_WHATSAPP=
GOOGLE_MAPS_API_KEY=
